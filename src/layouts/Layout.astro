---
import { DATA } from '../data/site';
import '../styles/global.css';

export interface Props {
  title?: string;
}

const { title = DATA.title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
</head>
<body>
  <div class="container">
    <header>
      <nav>
        <a href="/">Home</a>
        <a href="/about">About</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
        <p>&copy; {new Date().getFullYear()} {DATA.author} </p>
    </footer>
  </div>
</body>
</html>
