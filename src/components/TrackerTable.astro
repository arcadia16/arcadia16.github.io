---
export interface Props {
  headers: string[];
  rows: string[][]; // each inner array corresponds to a row's cells
  class?: string; // optional additional CSS classes
}

const { headers, rows, class: className } = Astro.props;
---

<div class="table-wrapper">
  <table class={`data-table ${className || ""}`}>
    <thead>
      <tr>
        {headers.map((header) => <th>{header}</th>)}
      </tr>
    </thead>
    <tbody>
      {
        rows.map((row) => (
          <tr>
            {row.map((cell) => (
              <td>{cell}</td>
            ))}
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

<style>
  .table-wrapper {
    overflow-x: auto;
    margin: 1rem 0;
  }
  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    background-color: var(--white);
    color: var(--black);
  }
  .data-table th,
  .data-table td {
    border: 1px solid var(--gray-light);
    padding: 0.75rem;
    text-align: left;
  }
  .data-table th {
    background-color: var(--gray-light);
    color: var(--accent);
    font-weight: 600;
  }
  .data-table tr:nth-child(even) {
    background-color: var(--gray-light);
  }
</style>
